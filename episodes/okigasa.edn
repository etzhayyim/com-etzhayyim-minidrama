[{:db/id -1, :episode/episode-id "okigasa", :episode/title "置き傘の返し方", :episode/logline "土砂降りの夜、名前も知らない人の傘を借りた。返すあてはビニール傘に貼られた一枚の付箋だけ。", :episode/genre "恋愛/日常", :episode/premise :live-action, :episode/duration-target 60, :episode/scenes "[{:seq 0, :setting \"駅の傘立て・豪雨の夜\", :shots [{:seq 0, :duration 6, :speaker :narrator-f, :prompt \"vertical 9:16 live-action, cinematic Japanese drama, heavy rain at night outside a small train station, a young woman in office wear stares at an empty umbrella stand, neon reflections on wet asphalt, shallow depth of field\", :subtitle \"傘、盗まれた。最悪。\"} {:seq 1, :duration 6, :speaker :woman-20s, :prompt \"vertical 9:16 live-action, close-up of a clear vinyl umbrella left in the stand with a yellow sticky note attached, rain blurring the background, cinematic lighting\", :subtitle \"『ご自由に。返すときは、ここに』……ここに？\"}]} {:seq 1, :setting \"一週間後・同じ傘立て\", :shots [{:seq 0, :duration 7, :speaker :woman-20s, :prompt \"vertical 9:16 live-action, the same station umbrella stand on a sunny evening, the woman carefully places the vinyl umbrella back with a new sticky note and a small box of chocolates, warm golden hour light\", :subtitle \"借りっぱなしは、性に合わない。\"} {:seq 1, :duration 7, :speaker :narrator-f, :prompt \"vertical 9:16 live-action, wide shot of the station at dusk, the woman walking away then glancing back at the umbrella stand, bokeh city lights\", :subtitle \"返した。これで終わり。……のはずだった。\"} {:seq 2, :duration 8, :speaker :man-20s, :prompt \"vertical 9:16 live-action, a young man in a raincoat picks up the umbrella, reads the note, smiles and looks around the station, cinematic close-up\", :subtitle \"『チョコは利子です』……律儀な人だな。\"}]} {:seq 2, :setting \"また雨の夜\", :shots [{:seq 0, :duration 8, :speaker :man-20s, :prompt \"vertical 9:16 live-action, rainy night again, the man stands by the stand holding TWO umbrellas, one clear one red, checking his phone nervously, rain on camera lens\", :subtitle \"今日は、直接返そうと思って。\"} {:seq 1, :duration 9, :speaker :woman-20s, :prompt \"vertical 9:16 live-action, the woman arrives running through rain and stops surprised, the man holds out the red umbrella, both laughing awkwardly under station lights, cinematic two-shot\", :subtitle \"傘、一本しか要らないんですけど。\"} {:seq 2, :duration 9, :speaker :narrator-f, :prompt \"vertical 9:16 live-action, from behind: two people walking away sharing one red umbrella in the rain, city bokeh, romantic cinematic wide shot\", :subtitle \"置き傘の返し方は、まだ知らない。\"}]}]"}]